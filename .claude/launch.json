{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dashboard",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),path=require('path');const s=http.createServer((req,res)=>{const f=path.join('C:/Claude/FestDash','festival-dashboard-v2.html');fs.readFile(f,(e,d)=>{if(e){res.writeHead(500);res.end('err');}else{res.writeHead(200,{'Content-Type':'text/html'});res.end(d);}});});s.listen(3848,()=>console.log('Server on 3848'));"],
      "port": 3848
    }
  ]
}
